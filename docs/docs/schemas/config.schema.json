{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tadashi-aikawa.github.io/jinrai/schemas/config.schema.json",
  "title": "JINRAI config.jsonc",
  "description": "JINRAI の config.jsonc 用 JSON Schema です。",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema の参照先です。",
      "default": "https://tadashi-aikawa.github.io/jinrai/schemas/config.schema.json"
    },
    "macosNativeTabs": {
      "$ref": "#/definitions/macosNativeTabs"
    },
    "jinraiMode": {
      "$ref": "#/definitions/jinraiMode"
    },
    "focusBack": {
      "$ref": "#/definitions/focusBack"
    },
    "focusBorder": {
      "$ref": "#/definitions/focusBorder"
    },
    "windowHints": {
      "$ref": "#/definitions/windowHints"
    },
    "windowMover": {
      "$ref": "#/definitions/windowMover"
    },
    "areaHints": {
      "$ref": "#/definitions/areaHints"
    },
    "applicationHints": {
      "$ref": "#/definitions/applicationHints"
    }
  },
  "definitions": {
    "color": {
      "type": "object",
      "description": "色です。各成分は 0 から 1 の数値です。",
      "additionalProperties": false,
      "properties": {
        "red": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0
        },
        "green": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0
        },
        "blue": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0
        },
        "alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        }
      }
    },
    "carbonModifierName": {
      "type": "string",
      "description": "Carbon グローバルホットキーで使える修飾キー名です。",
      "enum": ["cmd", "command", "alt", "option", "ctrl", "control", "shift"]
    },
    "eventModifierName": {
      "type": "string",
      "description": "キーストローク送出で使える修飾キー名です。",
      "enum": ["cmd", "command", "alt", "option", "ctrl", "control", "shift", "fn"]
    },
    "carbonModifiers": {
      "type": ["array", "null"],
      "items": {
        "$ref": "#/definitions/carbonModifierName"
      },
      "uniqueItems": true,
      "default": []
    },
    "eventModifiers": {
      "type": ["array", "null"],
      "items": {
        "$ref": "#/definitions/eventModifierName"
      },
      "uniqueItems": true,
      "default": []
    },
    "keyName": {
      "type": "string",
      "description": "キー名です。文字キー、return、escape、left、right、f1 から f20 などを指定できます。",
      "examples": ["a", "return", "escape", "left", "f20"]
    },
    "nullableKeyName": {
      "type": ["string", "null"],
      "description": "キー名です。null で未設定にできます。",
      "examples": ["a", "return", null]
    },
    "hotkey": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "modifiers": {
          "$ref": "#/definitions/carbonModifiers"
        },
        "key": {
          "$ref": "#/definitions/nullableKeyName"
        }
      }
    },
    "eventHotkey": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "modifiers": {
          "$ref": "#/definitions/eventModifiers"
        },
        "key": {
          "$ref": "#/definitions/nullableKeyName"
        }
      }
    },
    "direction": {
      "type": "string",
      "enum": ["left", "right", "up", "down", "upLeft", "upRight", "downLeft", "downRight"]
    },
    "directionKeyMap": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "left": {
          "$ref": "#/definitions/keyName"
        },
        "right": {
          "$ref": "#/definitions/keyName"
        },
        "up": {
          "$ref": "#/definitions/keyName"
        },
        "down": {
          "$ref": "#/definitions/keyName"
        },
        "upLeft": {
          "$ref": "#/definitions/keyName"
        },
        "upRight": {
          "$ref": "#/definitions/keyName"
        },
        "downLeft": {
          "$ref": "#/definitions/keyName"
        },
        "downRight": {
          "$ref": "#/definitions/keyName"
        }
      }
    },
    "animation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fade": {
          "type": "boolean",
          "default": true
        },
        "scale": {
          "type": "number",
          "default": 1
        },
        "duration": {
          "type": "number",
          "minimum": 0,
          "default": 0.16
        },
        "easing": {
          "type": "string",
          "enum": ["linear", "easeOut", "easeInOut"],
          "default": "linear"
        }
      }
    },
    "macosNativeTabs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apps": {
          "type": "array",
          "description": "組み込み対象へ追加する bundle ID またはアプリ名です。",
          "items": {
            "type": "string"
          },
          "default": ["com.mitchellh.ghostty", "com.apple.finder"]
        },
        "stateSyncInterval": {
          "type": "number",
          "minimum": 0,
          "default": 0.5
        }
      }
    },
    "jinraiModeTrigger": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {
          "$ref": "#/definitions/nullableKeyName"
        }
      }
    },
    "jinraiModeElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "animation": {
          "$ref": "#/definitions/animation"
        }
      }
    },
    "jinraiModeLogo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "size": {
          "type": "number",
          "minimum": 0,
          "default": 480
        },
        "alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.25
        },
        "animation": {
          "$ref": "#/definitions/animation"
        }
      }
    },
    "jinraiMode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "position": {
          "type": "string",
          "enum": ["activeWindow", "activeDisplay"],
          "default": "activeWindow"
        },
        "triggers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "windowHints": {
              "$ref": "#/definitions/jinraiModeTrigger"
            },
            "applicationHints": {
              "$ref": "#/definitions/jinraiModeTrigger"
            },
            "areaHints": {
              "$ref": "#/definitions/jinraiModeTrigger"
            }
          }
        },
        "logo": {
          "$ref": "#/definitions/jinraiModeLogo"
        },
        "combo": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "character": {
              "$ref": "#/definitions/jinraiModeElement"
            },
            "text": {
              "$ref": "#/definitions/jinraiModeElement"
            }
          }
        }
      }
    },
    "focusBack": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hotkey": {
          "$ref": "#/definitions/hotkey"
        },
        "urlEvent": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": ["string", "null"],
              "description": "URL イベント名です。"
            }
          }
        },
        "behavior": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cursor": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "onSelect": {
                  "type": "boolean",
                  "default": true
                }
              }
            }
          }
        }
      }
    },
    "focusBorder": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visual": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "border": {
              "$ref": "#/definitions/borderVisual"
            },
            "outline": {
              "$ref": "#/definitions/borderVisual"
            },
            "logo": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "source": {
                  "type": ["string", "null"]
                },
                "size": {
                  "type": "number",
                  "minimum": 0,
                  "default": 480
                },
                "alpha": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.95
                }
              }
            }
          }
        },
        "animation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "duration": {
              "type": "number",
              "minimum": 0,
              "default": 0.5
            },
            "fadeSteps": {
              "type": "integer",
              "minimum": 0,
              "default": 18
            },
            "spaceSwitchDelay": {
              "type": "number",
              "minimum": 0,
              "default": 0.3
            }
          }
        },
        "window": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minSize": {
              "type": "number",
              "minimum": 0,
              "default": 480
            }
          }
        }
      }
    },
    "borderVisual": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "number",
          "minimum": 0
        },
        "color": {
          "$ref": "#/definitions/color"
        }
      }
    },
    "hintStateStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bgColor": {
          "$ref": "#/definitions/color"
        },
        "highlight": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fillColor": {
              "$ref": "#/definitions/color"
            },
            "borderColor": {
              "$ref": "#/definitions/color"
            }
          }
        }
      }
    },
    "alphaState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "colorState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "color": {
          "$ref": "#/definitions/color"
        }
      }
    },
    "stateMapHint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "normal": {
          "$ref": "#/definitions/hintStateStyle"
        },
        "dimmed": {
          "$ref": "#/definitions/hintStateStyle"
        },
        "occluded": {
          "$ref": "#/definitions/hintStateStyle"
        },
        "active": {
          "$ref": "#/definitions/hintStateStyle"
        }
      }
    },
    "stateMapAlpha": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "normal": {
          "$ref": "#/definitions/alphaState"
        },
        "dimmed": {
          "$ref": "#/definitions/alphaState"
        },
        "occluded": {
          "$ref": "#/definitions/alphaState"
        },
        "active": {
          "$ref": "#/definitions/alphaState"
        }
      }
    },
    "stateMapColor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "normal": {
          "$ref": "#/definitions/colorState"
        },
        "dimmed": {
          "$ref": "#/definitions/colorState"
        },
        "occluded": {
          "$ref": "#/definitions/colorState"
        },
        "active": {
          "$ref": "#/definitions/colorState"
        }
      }
    },
    "prefixOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "match": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bundleID": {
              "type": "string"
            },
            "titleGlob": {
              "type": "string"
            }
          }
        },
        "prefix": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2
        }
      }
    },
    "windowHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hotkey": {
          "$ref": "#/definitions/hotkey"
        },
        "hint": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "chars": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": ["A", "S", "D", "F", "G", "H", "J", "K", "L", "Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P", "Z", "X", "C", "V", "B", "N", "M"]
            },
            "prefixOverrides": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/prefixOverride"
              },
              "default": []
            },
            "padding": {
              "type": "number",
              "minimum": 0,
              "default": 12
            },
            "cornerRadius": {
              "type": "number",
              "minimum": 0,
              "default": 12
            },
            "occludedScale": {
              "type": "number",
              "minimum": 0,
              "default": 0.85
            },
            "highlight": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "borderWidth": {
                  "type": "number",
                  "minimum": 0,
                  "default": 6
                }
              }
            },
            "state": {
              "$ref": "#/definitions/stateMapHint"
            },
            "icon": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "size": {
                  "type": "number",
                  "minimum": 0,
                  "default": 72
                },
                "state": {
                  "$ref": "#/definitions/stateMapAlpha"
                }
              }
            },
            "key": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "minWidth": {
                  "type": "number",
                  "minimum": 0,
                  "default": 72
                },
                "fontSize": {
                  "type": "number",
                  "minimum": 0,
                  "default": 48
                },
                "keyHighlightColor": {
                  "$ref": "#/definitions/color"
                },
                "state": {
                  "$ref": "#/definitions/stateMapColor"
                }
              }
            },
            "title": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "show": {
                  "type": "boolean",
                  "default": true
                },
                "fontSize": {
                  "type": "number",
                  "minimum": 0,
                  "default": 16
                },
                "maxSize": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 72
                },
                "state": {
                  "$ref": "#/definitions/stateMapColor"
                }
              }
            }
          }
        },
        "focusedWindowHighlight": {
          "$ref": "#/definitions/borderVisual"
        },
        "focusedWindowSpotlight": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "alpha": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.5
            }
          }
        },
        "occlusion": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "sampling": {
              "$ref": "#/definitions/sampling"
            },
            "preview": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "mode": {
                  "type": "string",
                  "enum": ["background", "below"],
                  "default": "background"
                },
                "width": {
                  "type": "number",
                  "minimum": 0,
                  "default": 140
                },
                "padding": {
                  "type": "number",
                  "minimum": 0,
                  "default": 6
                },
                "alpha": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.64
                }
              }
            }
          }
        },
        "dock": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bottomMargin": {
              "type": "number",
              "default": 96
            },
            "itemGap": {
              "type": "number",
              "default": 12
            },
            "windowBlend": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "x": {
                  "type": "number",
                  "default": 0.65
                },
                "y": {
                  "type": "number",
                  "default": 1
                }
              }
            }
          }
        },
        "navigation": {
          "$ref": "#/definitions/windowHintsNavigation"
        },
        "behavior": {
          "$ref": "#/definitions/windowHintsBehavior"
        }
      }
    },
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "baseWidth": {
          "type": "number",
          "minimum": 1,
          "default": 1920
        },
        "baseHeight": {
          "type": "number",
          "minimum": 1,
          "default": 1080
        },
        "minCols": {
          "type": "integer",
          "minimum": 1,
          "default": 4
        },
        "minRows": {
          "type": "integer",
          "minimum": 1,
          "default": 4
        },
        "maxCols": {
          "type": "integer",
          "minimum": 1,
          "default": 8
        },
        "maxRows": {
          "type": "integer",
          "minimum": 1,
          "default": 8
        }
      }
    },
    "windowHintsNavigation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "focusBack": {
          "$ref": "#/definitions/jinraiModeTrigger"
        },
        "areaHints": {
          "$ref": "#/definitions/jinraiModeTrigger"
        },
        "applicationHints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "key": {
              "$ref": "#/definitions/nullableKeyName"
            },
            "jinraiMode": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "direction": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hints": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "keys": {
                  "$ref": "#/definitions/directionKeyMap"
                }
              }
            },
            "direct": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "modifiers": {
                  "$ref": "#/definitions/carbonModifiers"
                },
                "keys": {
                  "$ref": "#/definitions/directionKeyMap"
                }
              }
            },
            "scoring": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "cardinalOverlapTieThresholdPx": {
                  "type": "number",
                  "minimum": 0,
                  "default": 720
                },
                "maxPrimaryOverlapRatioForDetached": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.2
                },
                "minOrthogonalOverlapRatio": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.5
                },
                "preferredVisibleRatio": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.4
                }
              }
            }
          }
        },
        "spaces": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "numbers": {
              "type": "boolean",
              "default": true
            },
            "prev": {
              "$ref": "#/definitions/jinraiModeTrigger"
            },
            "next": {
              "$ref": "#/definitions/jinraiModeTrigger"
            }
          }
        }
      }
    },
    "windowHintsBehavior": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cursor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "onSelect": {
              "type": "boolean",
              "default": true
            },
            "onStart": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "candidates": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "includeOtherSpaces": {
              "type": "boolean",
              "default": true
            },
            "includeActiveWindow": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "swapWindowFrame": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "modifiers": {
                  "$ref": "#/definitions/eventModifiers"
                }
              }
            }
          }
        },
        "showFadeIn": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hints": {
              "type": "number",
              "minimum": 0,
              "default": 0.05
            },
            "spotlight": {
              "type": "number",
              "minimum": 0,
              "default": 0.4
            }
          }
        }
      }
    },
    "windowMover": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "$ref": "#/definitions/windowMoverCommands"
        },
        "behavior": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cursor": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "afterMove": {
                  "type": "boolean",
                  "default": true
                }
              }
            },
            "cycle": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "horizontalRatios": {
                  "$ref": "#/definitions/ratioArray"
                },
                "verticalRatios": {
                  "$ref": "#/definitions/ratioArray"
                }
              }
            },
            "freeArea": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "hiddenWindowThreshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.5
                }
              }
            }
          }
        }
      }
    },
    "ratioArray": {
      "type": "array",
      "items": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "default": [0.5, 0.3333333333333333, 0.6666666666666666]
    },
    "windowMoverCommand": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hotkey": {
          "$ref": "#/definitions/hotkey"
        }
      }
    },
    "windowMoverCommands": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "moveToNextDisplay": {
