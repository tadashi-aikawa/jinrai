---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const brewCommand = "brew install --cask tadashi-aikawa/tap/jinrai";
---

<header class="hero">
  <div class="container grid">
    <div class="copy">
      <h1>
        <img
          class="logo"
          src={`${base}/images/jinrai-logo.png`}
          alt="JINRAI(迅雷)"
          width="1242"
          height="390"
          fetchpriority="high"
        />
      </h1>

      <p class="catch">『思考の速度でウィンドウ操作を』</p>
      <p class="sub">
        ウィンドウを素早く選択・移動できる<span class="mobile-line"
          >macOSの常駐アプリです。</span
        >
      </p>

      <div class="install-command">
        <code id="brew-command">{brewCommand}</code>
        <button id="copy-brew" type="button" aria-label="インストールコマンドをコピー">
          コピー
        </button>
      </div>

      <div class="cta">
        <a class="button primary" href="#features">
          <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
          <span class="label-full">機能を見る</span><span class="label-short">機能</span>
        </a>
        <a class="button" href={`${base}/docs/`}>
          <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>
          <span class="label-full">ドキュメント</span><span class="label-short">Docs</span>
        </a>
        <a class="button" href="https://github.com/tadashi-aikawa/jinrai">
          <svg aria-hidden="true" viewBox="0 0 16 16" width="18" height="18" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/></svg>
          GitHub
        </a>
      </div>
    </div>

    <div class="visual" aria-hidden="true">
      <img
        src={`${base}/images/jinrai-mini.webp`}
        alt=""
        width="1024"
        height="1536"
        fetchpriority="high"
      />
    </div>
  </div>

  <a class="scroll-cue" href="#features" aria-label="下へスクロール">
    <svg aria-hidden="true" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
  </a>
</header>

<script>
  const button = document.getElementById("copy-brew")!;
  const command = document.getElementById("brew-command")!.textContent!;
  button.addEventListener("click", async () => {
    await navigator.clipboard.writeText(command);
    button.textContent = "コピーしました";
    setTimeout(() => (button.textContent = "コピー"), 2000);
  });
</script>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    /* ファーストビューを Hero + 直下の稲妻区切り(14px)だけで構成する */
    min-height: calc(100vh - 14px);
    min-height: calc(100svh - 14px);
    padding: clamp(3rem, 9vh, 6rem) 0 4rem;
    overflow: hidden;
    background:
      repeating-linear-gradient(
        115deg,
        transparent 0 42px,
        rgba(255, 212, 0, 0.035) 42px 44px
      ),
      radial-gradient(
        ellipse 60% 70% at 22% 0%,
        rgba(255, 212, 0, 0.16),
        transparent
      ),
      radial-gradient(
        ellipse 55% 65% at 85% 65%,
        rgba(255, 212, 0, 0.1),
        transparent
      ),
      var(--bg);
  }

  .grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }

  /* grid アイテムの min-width:auto で nowrap のコマンドが列幅を押し広げるのを防ぐ */
  .copy,
  .visual {
    min-width: 0;
  }

  .copy {
    max-width: 680px;
    text-align: center;
  }

  h1 {
    line-height: 0;
  }

  .logo {
    width: min(600px, 100%);
    height: auto;
    filter: drop-shadow(0 0 2rem rgba(255, 212, 0, 0.3));
  }

  .catch {
    margin-top: 2.5rem;
    font-size: clamp(1.2rem, 2.5vw, 1.45rem);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.94);
  }

  .sub {
    margin-top: 0.5rem;
    color: var(--fg-muted);
    text-wrap: balance;
  }

  .install-command {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    padding: 0.65rem 0.75rem 0.65rem 1.25rem;
    background: rgba(16, 19, 26, 0.85);
    border: 1px solid var(--border);
    border-radius: 999px;
    max-width: 100%;
  }

  .install-command code {
    color: var(--jinrai-yellow-light);
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }

  .install-command button {
    flex-shrink: 0;
    padding: 0.3rem 0.9rem;
    font-size: 0.85rem;
    font-family: var(--font-sans);
    color: var(--jinrai-black);
    background: var(--jinrai-yellow);
    border: none;
    border-radius: 999px;
    cursor: pointer;
  }

  .install-command button:hover {
    background: var(--jinrai-yellow-light);
  }

  .cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.6rem;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    font-weight: 600;
    color: var(--jinrai-yellow);
    transition:
      background 0.15s,
      color 0.15s;
  }

  .button:hover {
    background: rgba(255, 212, 0, 0.12);
    color: var(--jinrai-yellow-light);
  }

  .button.primary {
    background: var(--jinrai-yellow);
    color: var(--jinrai-black);
  }

  .button.primary:hover {
    background: var(--jinrai-yellow-light);
  }

  /* スマホ幅では .label-short(短縮表現)へ切り替えて CTA を1行に収める */
  .label-short {
    display: none;
  }

  .visual {
    flex-shrink: 0;
    max-width: min(420px, 32vw);
  }

  .visual img {
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 0 3rem rgba(255, 212, 0, 0.25));
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-14px);
    }
  }

  .scroll-cue {
    position: absolute;
    inset-inline: 0;
    bottom: 1.1rem;
    width: fit-content;
    margin-inline: auto;
    line-height: 0;
    color: var(--jinrai-yellow);
    opacity: 0.6;
    animation: bob 2s ease-in-out infinite;
  }

  .scroll-cue:hover {
    opacity: 1;
  }

  @keyframes bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(7px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .visual img,
    .scroll-cue {
      animation: none;
    }
  }

  @media (max-width: 820px) {
    .container {
      width: calc(100% - 4.5rem);
    }

    .grid {
      flex-direction: column;
      gap: 2.5rem;
    }

    .copy {
      width: 100%;
    }

    .mobile-line {
      display: block;
    }

    .install-command code {
      font-size: 0.8rem;
    }

    .visual {
      max-width: 320px;
    }
  }

  @media (max-width: 560px) {
    .cta {
      flex-wrap: nowrap;
      gap: 0.4rem;
    }

    .button {
      padding: 0.5rem 0.85rem;
      font-size: 0.85rem;
      gap: 0.35rem;
    }

    .button svg {
      width: 16px;
      height: 16px;
    }

    .label-full {
      display: none;
    }

    .label-short {
      display: inline;
    }
  }
</style>
