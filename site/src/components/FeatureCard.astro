---
interface Props {
  id: string;
  title: string;
  tagline: string;
  description: string;
  icon: string;
  docPath: string;
  demo?: string;
}

const { id, title, tagline, description, icon, docPath, demo } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<article class="card" id={id}>
  <div class="head">
    <span class="icon" set:html={icon} />
    <div>
      <h3>{title}</h3>
      <p class="tagline">{tagline}</p>
    </div>
  </div>

  <p class="description">{description}</p>

  {
    demo ? (
      <video
        class="demo"
        src={`${base}/${demo}`}
        autoplay
        loop
        muted
        playsinline
      />
    ) : (
      <figure class="demo-placeholder" data-feature={id}>
        <span class="badge">DEMO</span>
        <span>デモ準備中</span>
      </figure>
    )
  }

  <a class="doc-link" href={`${base}/docs/${docPath}/`}>詳しく見る →</a>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 16px;
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--border-strong);
  }

  .head {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    color: var(--jinrai-yellow);
    background: rgba(255, 212, 0, 0.08);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  h3 {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.94);
    line-height: 1.3;
  }

  .tagline {
    font-size: 0.85rem;
    color: var(--jinrai-yellow);
  }

  .description {
    font-size: 0.95rem;
    color: var(--fg-muted);
    flex-grow: 1;
  }

  .demo {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(0, 0, 0, 0.25);
  }

  .demo-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    aspect-ratio: 16 / 10;
    border: 2px dashed rgba(255, 212, 0, 0.28);
    border-radius: 12px;
    color: var(--fg-faint);
    font-size: 0.9rem;
    background: rgba(0, 0, 0, 0.25);
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--jinrai-yellow-dark);
    border: 1px solid rgba(255, 212, 0, 0.28);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
  }

  .doc-link {
    font-size: 0.9rem;
    font-weight: 600;
    align-self: flex-end;
  }
</style>
